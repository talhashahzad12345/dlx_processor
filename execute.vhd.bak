library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
use work.dlx_pkg.all;

entity execute is
  port (
    clk : in std_logic;

    -- From Decode (already registered)
    regA        : in std_logic_vector(DATA_WIDTH-1 downto 0);
    regB        : in std_logic_vector(DATA_WIDTH-1 downto 0);
    imm         : in std_logic_vector(DATA_WIDTH-1 downto 0);
    rs          : in std_logic_vector(REG_ADDR_W-1 downto 0);
    rt          : in std_logic_vector(REG_ADDR_W-1 downto 0);
    rd          : in std_logic_vector(REG_ADDR_W-1 downto 0);
    pc_in       : in std_logic_vector(PC_WIDTH-1 downto 0);

    RegWrite_in : in std_logic;
    RegDst_in   : in std_logic;
    ALUSrc_in   : in std_logic;
    Branch_in   : in std_logic;
    Jump_in     : in std_logic;
    ALUOp_in    : in std_logic_vector(4 downto 0);

    -- To Fetch
    pc_src      : out std_logic_vector(1 downto 0);
    pc_target   : out std_logic_vector(PC_WIDTH-1 downto 0);

    -- To MEM stage
    alu_out     : out std_logic_vector(DATA_WIDTH-1 downto 0);
    rt_out      : out std_logic_vector(DATA_WIDTH-1 downto 0);
    dest_out    : out std_logic_vector(REG_ADDR_W-1 downto 0);
    RegWrite_out: out std_logic
  );
end entity;
