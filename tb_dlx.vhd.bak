library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

use work.dlx_pkg.all;

entity tb_dlx is
end entity;

architecture sim of tb_dlx is

  ------------------------------------------------------------------
  -- Clock / Reset
  ------------------------------------------------------------------
  signal clk : std_logic := '0';
  signal rst : std_logic := '1';

  ------------------------------------------------------------------
  -- Fetch control
  ------------------------------------------------------------------
  signal fetch_mux_sel   : std_logic := '0';
  signal fetch_jump_addr : std_logic_vector(PC_WIDTH-1 downto 0)
                            := (others => '0');

  ------------------------------------------------------------------
  -- Writeback (used for input injection)
  ------------------------------------------------------------------
  signal wb_we   : std_logic := '0';
  signal wb_addr : std_logic_vector(REG_ADDR_W-1 downto 0)
                    := (others => '0');
  signal wb_data : std_logic_vector(DATA_WIDTH-1 downto 0)
                    := (others => '0');

  ------------------------------------------------------------------
  -- Debug
  ------------------------------------------------------------------
  signal instr_dbg : std_logic_vector(DATA_WIDTH-1 downto 0);
  signal pc_dbg    : std_logic_vector(PC_WIDTH-1 downto 0);

begin

  ------------------------------------------------------------------
  -- DUT
  ------------------------------------------------------------------
  dut : entity work.dlx
    port map (
      clk => clk,
      rst => rst,

      fetch_mux_sel   => fetch_mux_sel,
      fetch_jump_addr => fetch_jump_addr,

      wb_we   => wb_we,
      wb_addr => wb_addr,
      wb_data => wb_data,

      instr_dbg => instr_dbg,
      pc_dbg    => pc_dbg,

      regA_dbg => open,
      regB_dbg => open,
      imm_dbg  => open,

      rs_dbg => open,
      rt_dbg => open,
      rd_dbg => open,

      RegWrite_dbg => open,
      RegDst_dbg   => open,
      ALUSrc_dbg   => open,
      Branch_dbg   => open,
      Jump_dbg     => open,
      ALUOp_dbg    => open
    );

  ------------------------------------------------------------------
  -- Clock generation
  ------------------------------------------------------------------
  clk <= not clk after 5 ns;

  ------------------------------------------------------------------
  -- Reset
  ------------------------------------------------------------------
  process
  begin
    rst <= '1';
    wait for 20 ns;
    rst <= '0';
    wait;
  end process;

  ------------------------------------------------------------------
  -- INPUT INJECTION
  -- Write input value = 3 into R1
  ------------------------------------------------------------------
  process
  begin
    wait until rst = '0';
    wait until rising_edge(clk);

    wb_we   <= '1';
    wb_addr <= std_logic_vector(to_unsigned(1, REG_ADDR_W)); -- R1
    wb_data <= std_logic_vector(to_unsigned(3, DATA_WIDTH));

    wait until rising_edge(clk);

    wb_we   <= '0';
    wb_addr <= (others => '0');
    wb_data <= (others => '0');

    report "Injected input value 3 into R1";
    wait;
  end process;

  ------------------------------------------------------------------
  -- FETCH / CONTROL EMULATION
  ------------------------------------------------------------------
  process(clk)
    variable opcode : std_logic_vector(5 downto 0);
    variable imm16  : std_logic_vector(15 downto 0);
    variable pc_i   : integer;
  begin
    if rising_edge(clk) then

      -- defaults
      fetch_mux_sel <= '0';
      fetch_jump_addr <= (others => '0');

      opcode := instr_dbg(31 downto 26);
      imm16  := instr_dbg(15 downto 0);
      pc_i   := to_integer(unsigned(pc_dbg));

      --------------------------------------------------------------
      -- Forced-taken control flow
      --------------------------------------------------------------
      if opcode = OP_J or opcode = OP_JAL then
        fetch_mux_sel   <= '1';
        fetch_jump_addr <= imm16(PC_WIDTH-1 downto 0);

      elsif opcode = OP_JR then
        fetch_mux_sel   <= '1';
        fetch_jump_addr <= std_logic_vector(to_unsigned(31, PC_WIDTH));

      elsif opcode = OP_BEQZ or opcode = OP_BNEZ then
        fetch_mux_sel   <= '1';
        fetch_jump_addr <= imm16(PC_WIDTH-1 downto 0);
      end if;

      --------------------------------------------------------------
      -- Trace
      --------------------------------------------------------------
      report
		  "FETCH | PC=" & integer'image(pc_i) &
		  " INSTR=" & integer'image(to_integer(unsigned(instr_dbg))) &
		  " MUX=" & std_logic'image(fetch_mux_sel);


    end if;
  end process;

end architecture;
