library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

use work.dlx_pkg.all;

entity decode is
  port (
    clk       : in  std_logic;
    rst       : in  std_logic;

    -- From FETCH
    instr_in  : in  std_logic_vector(DATA_WIDTH-1 downto 0);
    pc_in     : in  std_logic_vector(PC_WIDTH-1 downto 0);

    -- Writeback support (TB or WB stage)
    wb_we     : in  std_logic;
    wb_addr   : in  std_logic_vector(REG_ADDR_W-1 downto 0);
    wb_data   : in  std_logic_vector(DATA_WIDTH-1 downto 0);

    -- To EXECUTE (ID/EX)
    regA_out  : out std_logic_vector(DATA_WIDTH-1 downto 0);
    regB_out  : out std_logic_vector(DATA_WIDTH-1 downto 0);
    imm_out   : out std_logic_vector(DATA_WIDTH-1 downto 0);

    rs_out    : out std_logic_vector(REG_ADDR_W-1 downto 0);
    rt_out    : out std_logic_vector(REG_ADDR_W-1 downto 0);
    rd_out    : out std_logic_vector(REG_ADDR_W-1 downto 0);

    pc_out    : out std_logic_vector(PC_WIDTH-1 downto 0);

    -- Control signals
    RegWrite_out : out std_logic;
    RegDst_out   : out std_logic;
    ALUSrc_out   : out std_logic;
    Branch_out   : out std_logic;
    Jump_out     : out std_logic;
    ALUOp_out    : out std_logic_vector(4 downto 0)
  );
end entity decode;

architecture rtl of decode is

  ------------------------------------------------------------------
  -- IF/ID pipeline registers
  ------------------------------------------------------------------
  signal instr_d : std_logic_vector(DATA_WIDTH-1 downto 0);
  signal pc_d    : std_logic_vector(PC_WIDTH-1 downto 0);

  ------------------------------------------------------------------
  -- Instruction fields
  ------------------------------------------------------------------
  signal opcode : std_logic_vector(OPCODE_W-1 downto 0);
  signal rs     : std_logic_vector(REG_ADDR_W-1 downto 0);
  signal rt     : std_logic_vector(REG_ADDR_W-1 downto 0);
  signal rd     : std_logic_vector(REG_ADDR_W-1 downto 0);
  signal imm16  : std_logic_vector(IMM_W-1 downto 0);

  ------------------------------------------------------------------
  -- Register file outputs
  ------------------------------------------------------------------
  signal regA   : std_logic_vector(DATA_WIDTH-1 downto 0);
  signal regB   : std_logic_vector(DATA_WIDTH-1 downto 0);

  ------------------------------------------------------------------
  -- Sign-extended immediate
  ------------------------------------------------------------------
  signal imm_ext : std_logic_vector(DATA_WIDTH-1 downto 0);

  ------------------------------------------------------------------
  -- Decoded control signals
  ------------------------------------------------------------------
  signal RegWrite : std_logic;
  signal RegDst   : std_logic;
  signal ALUSrc   : std_logic;
  signal Branch   : std_logic;
  signal Jump     : std_logic;
  signal ALUOp    : std_logic_vector(4 downto 0);

begin

  ------------------------------------------------------------------
  -- IF/ID pipeline register
  ------------------------------------------------------------------
  process(clk)
  begin
    if rising_edge(clk) then
      if rst = '1' then
        instr_d <= (others => '0');
        pc_d    <= (others => '0');
      else
        instr_d <= instr_in;
        pc_d    <= pc_in;
      end if;
    end if;
  end process;

  ------------------------------------------------------------------
  -- Instruction field extraction
  ------------------------------------------------------------------
  opcode <= instr_d(31 downto 26);
  rs     <= instr_d(25 downto 21);
  rt     <= instr_d(20 downto 16);
  rd     <= instr_d(15 downto 11);
  imm16  <= instr_d(15 downto 0);

  ------------------------------------------------------------------
  -- Register file
  ------------------------------------------------------------------
  rf_inst : entity work.regfile
    port map (
      clk => clk,
      we  => wb_we,
      ra1 => rs,
      ra2 => rt,
      wa  => wb_addr,
      wd  => wb_data,
      rd1 => regA,
      rd2 => regB
    );

  ------------------------------------------------------------------
  -- Sign extension
  ------------------------------------------------------------------
  imm_ext <= (DATA_WIDTH-1 downto IMM_W => imm16(IMM_W-1)) & imm16;

  ------------------------------------------------------------------
  -- Control unit (decode logic)
  ------------------------------------------------------------------
  process(opcode)
	begin
	  -- Defaults
	  RegWrite <= '0';
	  RegDst   <= '1';   -- rd by default
	  ALUSrc   <= '0';
	  Branch   <= '0';
	  Jump     <= '0';
	  ALUOp    <= ALU_ADD;

	  case opcode is

		 -- =========================
		 -- No operation
		 -- =========================
		 when OP_NOP =>
			null;

		 -- =========================
		 -- Register-register ALU ops
		 -- =========================
		 when OP_ADD  => RegWrite <= '1'; ALUOp <= ALU_ADD;
		 when OP_ADDU => RegWrite <= '1'; ALUOp <= ALU_ADD;

		 when OP_SUB  => RegWrite <= '1'; ALUOp <= ALU_SUB;
		 when OP_SUBU => RegWrite <= '1'; ALUOp <= ALU_SUB;

		 when OP_AND  => RegWrite <= '1'; ALUOp <= ALU_AND;
		 when OP_OR   => RegWrite <= '1'; ALUOp <= ALU_OR;
		 when OP_XOR  => RegWrite <= '1'; ALUOp <= ALU_XOR;

		 when OP_SLL  => RegWrite <= '1'; ALUOp <= ALU_SLL;
		 when OP_SRL  => RegWrite <= '1'; ALUOp <= ALU_SRL;
		 when OP_SRA  => RegWrite <= '1'; ALUOp <= ALU_SRA;

		 -- =========================
		 -- Immediate ALU ops
		 -- =========================
		 when OP_ADDI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_ADD;
		 when OP_ADDUI => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_ADD;

		 when OP_SUBI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_SUB;
		 when OP_SUBUI => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_SUB;

		 when OP_ANDI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_AND;
		 when OP_ORI   => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_OR;
		 when OP_XORI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_XOR;

		 when OP_SLLI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_SLL;
		 when OP_SRLI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_SRL;
		 when OP_SRAI  => RegWrite <= '1'; ALUSrc <= '1'; ALUOp <= ALU_SRA;

		 -- =========================
		 -- Set / compare ops
		 -- =========================
		 when OP_SLT | OP_SLTI | OP_SLTU | OP_SLTUI =>
			RegWrite <= '1'; ALUSrc <= opcode(0); ALUOp <= ALU_SLT;

		 when OP_SGT | OP_SGTI | OP_SGTU | OP_SGTUI =>
			RegWrite <= '1'; ALUSrc <= opcode(0); ALUOp <= ALU_SGT;

		 when OP_SLE | OP_SLEI | OP_SLEU | OP_SLEUI =>
			RegWrite <= '1'; ALUSrc <= opcode(0); ALUOp <= ALU_SLE;

		 when OP_SGE | OP_SGEI | OP_SGEU | OP_SGEUI =>
			RegWrite <= '1'; ALUSrc <= opcode(0); ALUOp <= ALU_SGE;

		 when OP_SEQ | OP_SEQI =>
			RegWrite <= '1'; ALUSrc <= opcode(0); ALUOp <= ALU_SEQ;

		 when OP_SNE | OP_SNEI =>
			RegWrite <= '1'; ALUSrc <= opcode(0); ALUOp <= ALU_SNE;

		 -- =========================
		 -- Memory
		 -- =========================
		 when OP_LW =>
			RegWrite <= '1';
			ALUSrc   <= '1';
			ALUOp    <= ALU_ADD;

		 when OP_SW =>
			RegWrite <= '0';
			ALUSrc   <= '1';
			ALUOp    <= ALU_ADD;

		 -- =========================
		 -- Branch / Jump
		 -- =========================
		 when OP_BEQZ | OP_BNEZ =>
			Branch <= '1';
			ALUOp  <= ALU_SUB;

		 when OP_J | OP_JR | OP_JAL | OP_JALR =>
			Jump <= '1';

		 when others =>
			null;

	  end case;
	end process;


  ------------------------------------------------------------------
  -- ID/EX pipeline register
  ------------------------------------------------------------------
  process(clk)
  begin
    if rising_edge(clk) then
      if rst = '1' then
        regA_out     <= (others => '0');
        regB_out     <= (others => '0');
        imm_out      <= (others => '0');
        rs_out       <= (others => '0');
        rt_out       <= (others => '0');
        rd_out       <= (others => '0');
        pc_out       <= (others => '0');

        RegWrite_out <= '0';
        RegDst_out   <= '0';
        ALUSrc_out   <= '0';
        Branch_out   <= '0';
        Jump_out     <= '0';
        ALUOp_out    <= (others => '0');
      else
        regA_out     <= regA;
        regB_out     <= regB;
        imm_out      <= imm_ext;
        rs_out       <= rs;
        rt_out       <= rt;
        rd_out       <= rd;
        pc_out       <= pc_d;

        RegWrite_out <= RegWrite;
        RegDst_out   <= RegDst;
        ALUSrc_out   <= ALUSrc;
        Branch_out   <= Branch;
        Jump_out     <= Jump;
        ALUOp_out    <= ALUOp;
      end if;
    end if;
  end process;

end architecture rtl;
