library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

use work.dlx_pkg.all;

entity memory is
  port (

    clk  : in std_logic;
    rst  : in std_logic;

    -- From EXECUTE stage
    alu_result_in   : in  std_logic_vector(DATA_WIDTH-1 downto 0);
    regB_in         : in  std_logic_vector(DATA_WIDTH-1 downto 0); -- store data
    rd_in           : in  std_logic_vector(REG_ADDR_WIDTH-1 downto 0);

    mem_read_in     : in  std_logic;
    mem_write_in    : in  std_logic;
    reg_write_in    : in  std_logic;
    mem_to_reg_in   : in  std_logic;

    -- To WRITE-BACK stage
    mem_read_data_out : out std_logic_vector(DATA_WIDTH-1 downto 0);
    alu_result_out    : out std_logic_vector(DATA_WIDTH-1 downto 0);
    rd_out            : out std_logic_vector(REG_ADDR_WIDTH-1 downto 0);

    reg_write_out     : out std_logic;
    mem_to_reg_out    : out std_logic
  );
end memory;

architecture rtl of memory is

  signal mem_read_data : std_logic_vector(DATA_WIDTH-1 downto 0);

begin

  ------------------------------------------------------------
  -- Data Memory Instance
  ------------------------------------------------------------
  dmem_inst : entity work.dmem
    port map (
      clk        => clk,
      address    => alu_result_in,
      write_data => regB_in,
      mem_read   => mem_read_in,
      mem_write  => mem_write_in,
      read_data  => mem_read_data
    );

  ------------------------------------------------------------
  -- Pipeline Register (MEM/WB)
  ------------------------------------------------------------
  process(clk, rst)
  begin
    if rst = '1' then
      mem_read_data_out <= (others => '0');
      alu_result_out    <= (others => '0');
      rd_out            <= (others => '0');
      reg_write_out     <= '0';
      mem_to_reg_out    <= '0';

    elsif rising_edge(clk) then
      mem_read_data_out <= mem_read_data;
      alu_result_out    <= alu_result_in;
      rd_out            <= rd_in;
      reg_write_out     <= reg_write_in;
      mem_to_reg_out    <= mem_to_reg_in;
    end if;
  end process;

end rtl;